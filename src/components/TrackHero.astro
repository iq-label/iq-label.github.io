---
import type { Track } from '../types';
import IQResonator from './IQResonator.astro';
import JanguIcon from './icons/JanguIcon.astro';
import BukIcon from './icons/BukIcon.astro';
import GayageumIcon from './icons/GayageumIcon.astro';
import HaegeumIcon from './icons/HaegeumIcon.astro';
import DansoIcon from './icons/DansoIcon.astro';
import GeomungoIcon from './icons/GeomungoIcon.astro';

interface Props {
  track: Track;
}

const { track } = Astro.props;
const trackJson = JSON.stringify(track);

const iconMap: Record<string, any> = {
  janggu: JanguIcon,
  buk: BukIcon,
  gayageum: GayageumIcon,
  haegeum: HaegeumIcon,
  danso: DansoIcon,
  geomungo: GeomungoIcon,
};

const InstrumentIcon = iconMap[track.fusion_instrument] || JanguIcon;
const instrumentLabel = track.fusion_with_label || track.fusion_with;
---

<section class="track-hero">
  <div class="hero-resonator" aria-hidden="true">
    <div class="resonator-wrap">
      <IQResonator size={540} />
    </div>
  </div>

  <div class="hero-content">
    <div class="tag hero-tag">
      第 {track.number} 號 — LATEST DROP / NO. {track.number}
    </div>

    <h1 class="serif glow-cream hero-title">
      <a href={`/track/${track.id}`}>{track.title_ko}</a>
    </h1>

    <div class="hero-subtitle">
      {track.title_en}
    </div>

    <div class="mono hero-meta">
      <InstrumentIcon size={24} />
      <span class="serif instrument-label">
        {instrumentLabel}
      </span>
      <span class="fusion-op">⊗</span>
      <span>{track.genre}</span>
    </div>

    <button data-track={trackJson}>▶ PLAY · {track.duration_label}</button>
  </div>
</section>

<style>
  .track-hero {
    position: relative;
    max-width: 1080px;
    min-height: 330px;
    margin: 0 auto;
    padding: 64px 32px 56px;
    overflow: hidden;
    isolation: isolate;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 620px;
  }

  .hero-resonator {
    position: absolute;
    z-index: 0;
    top: 4px;
    left: clamp(180px, 21vw, 250px);
    width: clamp(500px, 50vw, 590px);
    pointer-events: none;
    opacity: 0.86;
  }

  .resonator-wrap,
  .resonator-wrap :global(svg) {
    width: 100%;
    height: auto;
  }

  .hero-tag {
    margin-bottom: 28px;
  }

  .hero-title {
    max-width: 600px;
    margin: 0 0 14px;
    font-size: clamp(48px, 6vw, 64px);
    font-weight: 500;
    line-height: 1.05;
  }

  .hero-subtitle {
    max-width: 400px;
    margin-bottom: 32px;
    color: var(--color-text-secondary);
    font-size: 17px;
    font-style: italic;
  }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 32px;
    color: var(--color-text-secondary);
    font-size: 14px;
  }

  .instrument-label {
    color: var(--color-text-primary);
    font-size: 15px;
    letter-spacing: 0;
  }

  @media (max-width: 820px) {
    .track-hero {
      min-height: 310px;
      padding: 56px 28px 48px;
    }

    .hero-resonator {
      top: 18px;
      left: 31%;
      width: 470px;
      opacity: 0.5;
    }
  }

  @media (max-width: 540px) {
    .track-hero {
      min-height: 310px;
      padding: 50px 24px 44px;
    }

    .hero-resonator {
      top: 28px;
      left: 13%;
      width: 380px;
      opacity: 0.32;
    }

    .hero-title {
      font-size: 42px;
    }

    .hero-meta {
      align-items: flex-start;
      flex-wrap: wrap;
      gap: 10px 12px;
    }
  }
</style>
