---
import QMark from './QMark.astro';
import DancheongLine from './DancheongLine.astro';

const navItems = [
  { href: '/genres', label: 'genres' },
  { href: '/manifesto', label: 'manifesto' },
  { href: '/about', label: 'about' },
];
---

<header class="site-header">
  <div class="site-header-inner">
    <a href="/" class="brand-mark">
      <span class="brand-symbol">
        <QMark size={28} />
      </span>
      <div class="brand-lockup">
        <span class="serif glow-cream brand-title">
          Label Q
        </span>
        <span class="mono brand-subtitle">
          라벨 큐 · iq-label
        </span>
      </div>
    </a>
    <nav class="mono site-nav" aria-label="Primary navigation">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
  </div>
  <DancheongLine />
</header>

<style>
  .site-header {
    max-width: 1080px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .site-header-inner {
    padding: 26px 32px 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
  }

  .brand-mark {
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: max-content;
  }

  .brand-symbol {
    color: var(--color-text-primary);
    line-height: 0;
  }

  .brand-lockup {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .brand-title {
    font-size: 22px;
    font-weight: 500;
    line-height: 1;
  }

  .brand-subtitle {
    color: var(--color-text-faded);
    font-size: 9px;
    letter-spacing: 0.18em;
    white-space: nowrap;
  }

  .site-nav {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 24px;
    color: var(--color-text-secondary);
    font-size: 12px;
  }

  .site-nav a {
    position: relative;
    padding: 4px 0;
  }

  .site-nav a::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -3px;
    height: 1px;
    background: var(--color-dancheong-red);
    opacity: 0;
    transform: scaleX(0.35);
    transform-origin: center;
    transition: opacity 0.2s, transform 0.2s;
  }

  .site-nav a:hover::after {
    opacity: 0.8;
    transform: scaleX(1);
  }

  @media (max-width: 640px) {
    .site-header-inner {
      padding: 24px 20px 14px;
      gap: 18px;
    }

    .brand-mark {
      gap: 10px;
    }

    .brand-title {
      font-size: 20px;
    }

    .brand-subtitle {
      font-size: 8.5px;
      letter-spacing: 0.14em;
    }

    .site-nav {
      gap: 15px;
      font-size: 11px;
      letter-spacing: 0.06em;
    }
  }

  @media (max-width: 380px) {
    .site-header-inner {
      align-items: flex-start;
      flex-direction: column;
      gap: 14px;
    }

    .site-nav {
      width: 100%;
      justify-content: space-between;
    }
  }
</style>
