---
interface Props {
  size?: number;
  color?: string;
  accentColor?: string;
}

const {
  size = 380,
  color = 'var(--color-text-primary)',
  accentColor = 'var(--color-dancheong-red)',
} = Astro.props;
---

<svg
  width={size}
  height={size * 0.625}
  viewBox="0 0 320 200"
  fill="none"
  aria-label="부채"
  role="img"
  style="filter: drop-shadow(0 0 22px rgba(242, 234, 216, 0.12));"
>
  <g stroke={color} stroke-width="0.7" stroke-linecap="round" opacity="0.85">
    <line x1="160" y1="180" x2="20" y2="142" />
    <line x1="160" y1="180" x2="34" y2="108" />
    <line x1="160" y1="180" x2="58" y2="78" />
    <line x1="160" y1="180" x2="88" y2="54" />
    <line x1="160" y1="180" x2="122" y2="40" />
    <line x1="160" y1="180" x2="160" y2="35" stroke-width="1" />
    <line x1="160" y1="180" x2="198" y2="40" />
    <line x1="160" y1="180" x2="232" y2="54" />
    <line x1="160" y1="180" x2="262" y2="78" />
    <line x1="160" y1="180" x2="286" y2="108" />
    <line x1="160" y1="180" x2="300" y2="142" />
  </g>

  <path
    d="M 20 142 A 150 150 0 0 1 300 142"
    stroke={color}
    stroke-width="1.1"
    fill="none"
    stroke-linecap="round"
    opacity="0.9"
  />
  <path
    d="M 30 146 A 140 140 0 0 1 290 146"
    stroke={accentColor}
    stroke-width="0.5"
    fill="none"
    opacity="0.55"
  />
  <path
    d="M 56 158 A 110 110 0 0 1 264 158"
    stroke={color}
    stroke-width="0.4"
    fill="none"
    opacity="0.45"
  />
  <path
    d="M 81 168 A 80 80 0 0 1 239 168"
    stroke={color}
    stroke-width="0.35"
    fill="none"
    opacity="0.3"
  />

  <g fill={accentColor}>
    <circle cx="100" cy="85" r="1.8">
      <animate attributeName="opacity" values="0.5;1;0.5" dur="4s" repeatCount="indefinite" />
    </circle>
    <circle cx="160" cy="65" r="2.2">
      <animate attributeName="opacity" values="0.7;1;0.7" dur="3.5s" repeatCount="indefinite" />
    </circle>
    <circle cx="220" cy="85" r="1.8">
      <animate
        attributeName="opacity"
        values="0.5;1;0.5"
        dur="4.5s"
        repeatCount="indefinite"
        begin="1s"
      />
    </circle>
  </g>

  <g fill={color} opacity="0.6">
    <circle cx="76" cy="125" r="1" />
    <circle cx="130" cy="105" r="0.85" />
    <circle cx="190" cy="105" r="0.85" />
    <circle cx="244" cy="125" r="1" />
  </g>

  <g fill={color} opacity="0.7">
    <circle cx="20" cy="142" r="0.7" />
    <circle cx="34" cy="108" r="0.7" />
    <circle cx="58" cy="78" r="0.7" />
    <circle cx="88" cy="54" r="0.7" />
    <circle cx="122" cy="40" r="0.7" />
    <circle cx="160" cy="35" r="0.9" />
    <circle cx="198" cy="40" r="0.7" />
    <circle cx="232" cy="54" r="0.7" />
    <circle cx="262" cy="78" r="0.7" />
    <circle cx="286" cy="108" r="0.7" />
    <circle cx="300" cy="142" r="0.7" />
  </g>

  <circle cx="160" cy="180" r="8" fill="none" stroke={accentColor} stroke-width="0.5" opacity="0.35" />
  <circle cx="160" cy="180" r="5" fill="none" stroke={accentColor} stroke-width="0.7" opacity="0.7" />
  <circle
    cx="160"
    cy="180"
    r="3"
    fill={accentColor}
    style="filter: drop-shadow(0 0 10px rgba(232, 72, 82, 0.8));"
  />

  <line
    x1="160"
    y1="184"
    x2="160"
    y2="194"
    stroke={accentColor}
    stroke-width="0.6"
    stroke-linecap="round"
    opacity="0.7"
  />
  <circle cx="160" cy="196" r="1.5" fill={accentColor} opacity="0.85" />
</svg>
