---
const stars = Array.from({ length: 140 }, (_, i) => {
  const seedA = ((i * 9301 + 49297) % 233280) / 233280;
  const seedB = ((i * 1664 + 1013) % 233280) / 233280;
  const seedC = ((i * 7919 + 3001) % 233280) / 233280;
  const seedD = ((i * 4271 + 1597) % 233280) / 233280;
  return {
    x: seedA * 100,
    y: seedB * 100,
    r: seedC * 1.1 + 0.3,
    opacity: seedD * 0.6 + 0.2,
    twinkle: i % 7 === 0,
    twinkleDelay: (i % 11) * 0.4,
  };
});

const dustParticles = Array.from({ length: 40 }, (_, i) => {
  const seedA = ((i * 1597 + 911) % 233280) / 233280;
  const seedB = ((i * 4421 + 13) % 233280) / 233280;
  return {
    x: seedA * 100,
    y: seedB * 100,
    r: ((i * 3) % 10) / 8 + 0.4,
  };
});
---

<div class="cosmic-bg" aria-hidden="true">
  <svg
    width="100%"
    height="100%"
    viewBox="0 0 100 100"
    preserveAspectRatio="xMidYMid slice"
    style="position: absolute; inset: 0;"
  >
    <defs>
      <radialGradient id="supernova" cx="78%" cy="20%" r="20%">
        <stop offset="0%" stop-color="rgba(232, 72, 82, 0.28)" />
        <stop offset="40%" stop-color="rgba(232, 72, 82, 0.10)" />
        <stop offset="100%" stop-color="rgba(232, 72, 82, 0)" />
      </radialGradient>
      <radialGradient id="supernova-core" cx="78%" cy="20%" r="3%">
        <stop offset="0%" stop-color="rgba(255, 220, 200, 0.6)" />
        <stop offset="100%" stop-color="rgba(232, 72, 82, 0)" />
      </radialGradient>
      <radialGradient id="distant-glow" cx="20%" cy="68%" r="22%">
        <stop offset="0%" stop-color="rgba(139, 111, 191, 0.12)" />
        <stop offset="100%" stop-color="rgba(139, 111, 191, 0)" />
      </radialGradient>
    </defs>

    <rect width="100" height="100" fill="url(#supernova)" />
    <rect width="100" height="100" fill="url(#distant-glow)" />
    <rect width="100" height="100" fill="url(#supernova-core)" />

    <circle cx="78" cy="18" r="0.4" fill="rgba(255, 220, 200, 0.7)">
      <animate attributeName="r" values="0.3;0.6;0.3" dur="4s" repeatCount="indefinite" />
      <animate attributeName="opacity" values="0.5;0.9;0.5" dur="4s" repeatCount="indefinite" />
    </circle>

    {
      dustParticles.map((p) => (
        <circle cx={p.x} cy={p.y} r={p.r * 0.04} fill="rgba(212, 178, 122, 0.4)" />
      ))
    }

    {
      stars.map((s) => (
        <circle
          cx={s.x}
          cy={s.y}
          r={s.r * 0.05}
          fill="rgb(242, 234, 216)"
          opacity={s.opacity}
          style={s.twinkle ? `animation: twinkle 4s ease-in-out infinite; animation-delay: ${s.twinkleDelay}s;` : ''}
        />
      ))
    }
  </svg>

  <div class="ripple-layer">
    <span class="ripple ripple-red ripple-r1"></span>
    <span class="ripple ripple-red ripple-r2"></span>
    <span class="ripple ripple-red ripple-r3"></span>
    <span class="ripple ripple-purple ripple-p1"></span>
    <span class="ripple ripple-purple ripple-p2"></span>
    <span class="ripple ripple-center ripple-c1"></span>
  </div>
</div>

<style>
  .ripple-layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .ripple {
    position: absolute;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    width: 0;
    height: 0;
    box-sizing: border-box;
  }

  .ripple-red {
    top: 18%;
    left: 78%;
    border: 2px solid rgba(232, 72, 82, 0.6);
    animation: ripple-red-anim 10s ease-out infinite;
  }
  .ripple-r1 { animation-delay: 0s; }
  .ripple-r2 { animation-delay: 3.3s; }
  .ripple-r3 { animation-delay: 6.6s; }

  .ripple-purple {
    top: 68%;
    left: 22%;
    border: 1.5px solid rgba(139, 111, 191, 0.5);
    animation: ripple-purple-anim 13s ease-out infinite;
  }
  .ripple-p1 { animation-delay: 1.5s; }
  .ripple-p2 { animation-delay: 8s; }

  .ripple-center {
    top: 50%;
    left: 50%;
    border: 1px solid rgba(212, 178, 122, 0.35);
    animation: ripple-center-anim 16s ease-out infinite;
  }
  .ripple-c1 { animation-delay: 5s; }

  @keyframes ripple-red-anim {
    0% {
      width: 10px;
      height: 10px;
      opacity: 0.75;
      border-width: 2.5px;
    }
    100% {
      width: 1600px;
      height: 1600px;
      opacity: 0;
      border-width: 0.4px;
    }
  }

  @keyframes ripple-purple-anim {
    0% {
      width: 8px;
      height: 8px;
      opacity: 0.55;
      border-width: 2px;
    }
    100% {
      width: 1400px;
      height: 1400px;
      opacity: 0;
      border-width: 0.3px;
    }
  }

  @keyframes ripple-center-anim {
    0% {
      width: 12px;
      height: 12px;
      opacity: 0.4;
      border-width: 1.5px;
    }
    100% {
      width: 1800px;
      height: 1800px;
      opacity: 0;
      border-width: 0.2px;
    }
  }
</style>
