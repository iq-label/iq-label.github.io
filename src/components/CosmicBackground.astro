---
const stars = Array.from({ length: 180 }, (_, i) => {
  const seedA = ((i * 9301 + 49297) % 233280) / 233280;
  const seedB = ((i * 1664 + 1013) % 233280) / 233280;
  const seedC = ((i * 7919 + 3001) % 233280) / 233280;
  const seedD = ((i * 4271 + 1597) % 233280) / 233280;
  return {
    x: seedA * 100,
    y: seedB * 100,
    r: seedC * 1.4 + 0.4,
    opacity: seedD * 0.6 + 0.3,
    twinkle: i % 5 === 0,
    twinkleDelay: (i % 13) * 0.35,
  };
});

const dustParticles = Array.from({ length: 60 }, (_, i) => {
  const seedA = ((i * 1597 + 911) % 233280) / 233280;
  const seedB = ((i * 4421 + 13) % 233280) / 233280;
  return {
    x: seedA * 100,
    y: seedB * 100,
    r: ((i * 3) % 10) / 8 + 0.4,
  };
});
---

<div class="cosmic-bg" aria-hidden="true">
  <div class="atmospheric-pulse"></div>

  <svg
    width="100%"
    height="100%"
    viewBox="0 0 100 100"
    preserveAspectRatio="xMidYMid slice"
    style="position: absolute; inset: 0;"
  >
    <defs>
      <radialGradient id="supernova-main" cx="78%" cy="20%" r="32%">
        <stop offset="0%" stop-color="rgba(232, 72, 82, 0.42)" />
        <stop offset="25%" stop-color="rgba(232, 72, 82, 0.20)" />
        <stop offset="60%" stop-color="rgba(232, 72, 82, 0.06)" />
        <stop offset="100%" stop-color="rgba(232, 72, 82, 0)" />
      </radialGradient>
      <radialGradient id="supernova-core-bright" cx="78%" cy="20%" r="5%">
        <stop offset="0%" stop-color="rgba(255, 230, 210, 0.85)" />
        <stop offset="40%" stop-color="rgba(232, 100, 110, 0.4)" />
        <stop offset="100%" stop-color="rgba(232, 72, 82, 0)" />
      </radialGradient>
      <radialGradient id="distant-glow" cx="18%" cy="72%" r="30%">
        <stop offset="0%" stop-color="rgba(139, 111, 191, 0.22)" />
        <stop offset="50%" stop-color="rgba(139, 111, 191, 0.08)" />
        <stop offset="100%" stop-color="rgba(139, 111, 191, 0)" />
      </radialGradient>
      <radialGradient id="amber-cluster" cx="92%" cy="92%" r="20%">
        <stop offset="0%" stop-color="rgba(212, 178, 122, 0.16)" />
        <stop offset="100%" stop-color="rgba(212, 178, 122, 0)" />
      </radialGradient>
      <radialGradient id="cyan-glow" cx="40%" cy="50%" r="40%">
        <stop offset="0%" stop-color="rgba(74, 111, 165, 0.10)" />
        <stop offset="100%" stop-color="rgba(74, 111, 165, 0)" />
      </radialGradient>
    </defs>

    <rect width="100" height="100" fill="url(#cyan-glow)" />
    <rect width="100" height="100" fill="url(#supernova-main)" />
    <rect width="100" height="100" fill="url(#distant-glow)" />
    <rect width="100" height="100" fill="url(#amber-cluster)" />
    <rect width="100" height="100" fill="url(#supernova-core-bright)" />

    <g class="orbital-system">
      <ellipse
        cx="78"
        cy="20"
        rx="14"
        ry="14"
        fill="none"
        stroke="rgba(232, 72, 82, 0.18)"
        stroke-width="0.08"
        stroke-dasharray="0.6 1.2"
      />
      <ellipse
        cx="78"
        cy="20"
        rx="22"
        ry="22"
        fill="none"
        stroke="rgba(232, 72, 82, 0.12)"
        stroke-width="0.06"
        stroke-dasharray="0.4 2"
      />
    </g>

    <circle cx="78" cy="20" r="0.6" fill="rgba(255, 230, 210, 0.95)">
      <animate attributeName="r" values="0.5;0.95;0.5" dur="3.5s" repeatCount="indefinite" />
      <animate attributeName="opacity" values="0.7;1;0.7" dur="3.5s" repeatCount="indefinite" />
    </circle>

    <circle cx="18" cy="72" r="0.4" fill="rgba(180, 150, 220, 0.8)">
      <animate attributeName="r" values="0.3;0.6;0.3" dur="5s" repeatCount="indefinite" />
      <animate attributeName="opacity" values="0.5;0.9;0.5" dur="5s" repeatCount="indefinite" />
    </circle>

    {
      dustParticles.map((p) => (
        <circle cx={p.x} cy={p.y} r={p.r * 0.05} fill="rgba(212, 178, 122, 0.5)" />
      ))
    }

    {
      stars.map((s) => (
        <circle
          cx={s.x}
          cy={s.y}
          r={s.r * 0.06}
          fill="rgb(242, 234, 216)"
          opacity={s.opacity}
          style={s.twinkle ? `animation: twinkle 3.5s ease-in-out infinite; animation-delay: ${s.twinkleDelay}s;` : ''}
        />
      ))
    }
  </svg>

  <div class="ripple-layer">
    <span class="ripple ripple-red ripple-r1"></span>
    <span class="ripple ripple-red ripple-r2"></span>
    <span class="ripple ripple-red ripple-r3"></span>
    <span class="ripple ripple-purple ripple-p1"></span>
    <span class="ripple ripple-purple ripple-p2"></span>
    <span class="ripple ripple-center ripple-c1"></span>

    <span class="meteor meteor-1"></span>
    <span class="meteor meteor-2"></span>
    <span class="meteor meteor-3"></span>
  </div>
</div>

<style>
  .cosmic-bg {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: -1;
    overflow: hidden;
  }

  .atmospheric-pulse {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 70% 50% at 50% 50%,
      rgba(232, 72, 82, 0.08),
      transparent 70%
    );
    animation: atmosphere-breathe 9s ease-in-out infinite;
    transform-origin: center;
  }

  @keyframes atmosphere-breathe {
    0%, 100% {
      opacity: 0.4;
      transform: scale(1);
    }
    50% {
      opacity: 0.9;
      transform: scale(1.08);
    }
  }

  .orbital-system {
    transform-origin: 78px 20px;
    animation: orbital-rotate 90s linear infinite;
    transform-box: view-box;
  }

  @keyframes orbital-rotate {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  .ripple-layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .ripple {
    position: absolute;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    width: 0;
    height: 0;
    box-sizing: border-box;
  }

  .ripple-red {
    top: 18%;
    left: 78%;
    border: 2.5px solid rgba(232, 72, 82, 0.7);
    animation: ripple-red-anim 9s ease-out infinite;
  }
  .ripple-r1 { animation-delay: 0s; }
  .ripple-r2 { animation-delay: 3s; }
  .ripple-r3 { animation-delay: 6s; }

  .ripple-purple {
    top: 70%;
    left: 18%;
    border: 2px solid rgba(139, 111, 191, 0.6);
    animation: ripple-purple-anim 11s ease-out infinite;
  }
  .ripple-p1 { animation-delay: 1s; }
  .ripple-p2 { animation-delay: 6s; }

  .ripple-center {
    top: 50%;
    left: 50%;
    border: 1.5px solid rgba(212, 178, 122, 0.4);
    animation: ripple-center-anim 14s ease-out infinite;
  }
  .ripple-c1 { animation-delay: 4s; }

  @keyframes ripple-red-anim {
    0% {
      width: 12px;
      height: 12px;
      opacity: 0.8;
      border-width: 3px;
    }
    100% {
      width: 2400px;
      height: 2400px;
      opacity: 0;
      border-width: 0.4px;
    }
  }

  @keyframes ripple-purple-anim {
    0% {
      width: 10px;
      height: 10px;
      opacity: 0.6;
      border-width: 2.5px;
    }
    100% {
      width: 2000px;
      height: 2000px;
      opacity: 0;
      border-width: 0.3px;
    }
  }

  @keyframes ripple-center-anim {
    0% {
      width: 16px;
      height: 16px;
      opacity: 0.5;
      border-width: 2px;
    }
    100% {
      width: 2600px;
      height: 2600px;
      opacity: 0;
      border-width: 0.2px;
    }
  }

  .meteor {
    position: absolute;
    width: 2px;
    height: 90px;
    background: linear-gradient(
      to bottom,
      transparent,
      rgba(255, 230, 210, 0.95),
      transparent
    );
    transform: rotate(35deg);
    opacity: 0;
    filter: blur(0.4px);
    border-radius: 50%;
  }

  .meteor-1 {
    top: -15%;
    left: 90%;
    animation: meteor-fall 11s linear infinite;
    animation-delay: 1s;
  }

  .meteor-2 {
    top: -10%;
    left: 70%;
    animation: meteor-fall 13s linear infinite;
    animation-delay: 6s;
  }

  .meteor-3 {
    top: -20%;
    left: 50%;
    height: 60px;
    animation: meteor-fall 15s linear infinite;
    animation-delay: 10s;
    opacity: 0;
  }

  @keyframes meteor-fall {
    0% {
      transform: translate(0, 0) rotate(35deg);
      opacity: 0;
    }
    3% {
      opacity: 0;
    }
    8% {
      opacity: 1;
    }
    20% {
      transform: translate(-700px, 1000px) rotate(35deg);
      opacity: 0;
    }
    100% {
      transform: translate(-700px, 1000px) rotate(35deg);
      opacity: 0;
    }
  }
</style>
